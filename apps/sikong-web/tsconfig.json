{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "types": ["bun"],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "semajsx",
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "vendor/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
