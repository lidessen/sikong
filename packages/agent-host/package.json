{
  "name": "@sikong/agent-host",
  "version": "0.0.0",
  "private": true,
  "description": "Bun-side Sikong agent runtime host process.",
  "type": "module",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build:runtime-host": "bun build --compile ./src/runtime-host.ts --outfile ../../dist/siko-agent-host",
    "typecheck": "tsgo --project tsconfig.json",
    "test": "bun test ./src",
    "runtime-host": "bun ./src/runtime-host.ts"
  },
  "dependencies": {
    "agent-loop": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260613.1"
  }
}
