#!/usr/bin/env node
// Cross-platform launcher. npm installs exactly one matching `sikong-<platform>`
// package (gated by os/cpu/libc); this shim resolves its prebuilt binary and execs
// it. Falls back to a locally built `dist/sikong` for the dev workflow.
import { spawnSync } from "node:child_process";
import { existsSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";

function detectLibc() {
  if (process.platform !== "linux") return null;
  // glibc exposes glibcVersionRuntime in the process report header; musl does not.
  try {
    return process.report?.getReport?.()?.header?.glibcVersionRuntime ? "glibc" : "musl";
  } catch {
    return "glibc";
  }
}

function platformKey() {
  const { platform, arch } = process;
  if (platform === "win32" && arch === "x64") return "windows-x64";
  if (platform === "darwin" && arch === "arm64") return "darwin-arm64";
  if (platform === "darwin" && arch === "x64") return "darwin-x64";
  if (platform === "linux" && (arch === "x64" || arch === "arm64")) {
    const suffix = detectLibc() === "musl" ? "-musl" : "";
    return `linux-${arch}${suffix}`;
  }
  return null;
}

const here = dirname(fileURLToPath(import.meta.url)); // node_modules/sikong/bin
const key = platformKey();
const binName = process.platform === "win32" ? "sikong.exe" : "sikong";

function resolveBinary() {
  if (key) {
    const spec = `sikong-${key}/bin/${binName}`;
    // Preferred: ESM resolution honours hoisting and pnpm layouts (Node >= 20.6).
    if (typeof import.meta.resolve === "function") {
      try {
        const path = fileURLToPath(import.meta.resolve(spec));
        if (existsSync(path)) return path;
      } catch {
        // platform package not installed — try filesystem siblings, then dev build
      }
    }
    // Fallback for older Node: look beside / under this package in node_modules.
    const candidates = [
      join(here, "..", "..", `sikong-${key}`, "bin", binName),
      join(here, "..", "node_modules", `sikong-${key}`, "bin", binName),
    ];
    for (const path of candidates) if (existsSync(path)) return path;
  }
  const local = join(here, "..", "dist", "sikong");
  return existsSync(local) ? local : null;
}

const binary = resolveBinary();
if (!binary) {
  const supported =
    "darwin-arm64, darwin-x64, linux-x64[-musl], linux-arm64[-musl], windows-x64";
  console.error(
    `sikong: no prebuilt binary for ${process.platform}/${process.arch}` +
      (key ? ` (expected package sikong-${key})` : " (unsupported platform)") +
      `.\nSupported platforms: ${supported}.`,
  );
  process.exit(1);
}

const result = spawnSync(binary, process.argv.slice(2), { stdio: "inherit" });
if (result.error) {
  console.error(result.error.message);
  process.exit(1);
}
process.exit(result.status ?? 0);
