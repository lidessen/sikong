{
  "name": "sikong",
  "version": "0.1.7",
  "description": "Durable wake-loop workspace for agent-driven project development.",
  "type": "module",
  "bin": {
    "sikong": "bin/sikong"
  },
  "files": [
    "bin/sikong",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun run build:cli",
    "build:cli": "bun build src/cli.ts --compile --outfile dist/sikong",
    "build:platforms": "bun scripts/build-platforms.ts",
    "release": "bun scripts/release.ts",
    "release:dry": "bun scripts/release.ts --dry-run",
    "promotion:evidence": "bun scripts/promotion-evidence.ts",
    "prepublishOnly": "bun run typecheck && bun run test",
    "smoke:deepseek-tools": "bun smokes/smoke-deepseek-project-tools.ts",
    "self-smoke": "bun scripts/self-smoke.ts",
    "self-smoke:keep": "bun scripts/self-smoke.ts --keep-tmp",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest"
  },
  "keywords": [
    "agent",
    "ai-agent",
    "cli",
    "workflow",
    "workspace",
    "automation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lidessen/sikong.git",
    "directory": "packages/sikong"
  },
  "bugs": {
    "url": "https://github.com/lidessen/sikong/issues"
  },
  "homepage": "https://github.com/lidessen/sikong/tree/main/packages/sikong#readme",
  "optionalDependencies": {
    "sikong-darwin-arm64": "0.1.7",
    "sikong-darwin-x64": "0.1.7",
    "sikong-linux-x64": "0.1.7",
    "sikong-linux-arm64": "0.1.7",
    "sikong-linux-x64-musl": "0.1.7",
    "sikong-linux-arm64-musl": "0.1.7",
    "sikong-windows-x64": "0.1.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "agent-loop": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
