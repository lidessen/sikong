{
  "name": "agent-workspace",
  "version": "0.0.0",
  "description": "Workspace layer over agent-loop — multi-agent coordination. Scope TBD (placeholder).",
  "type": "module",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "bun run build:cli",
    "build:cli": "bun build src/cli.ts --compile --outfile dist/agent-workspace",
    "smoke:deepseek-tools": "bun smokes/smoke-deepseek-project-tools.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest"
  },
  "license": "MIT",
  "dependencies": {
    "agent-loop": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
