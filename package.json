{
  "name": "sikong",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:go",
    "build:go": "go build -o dist/sikong ./cmd/sikong && go build -o dist/sikongd ./cmd/sikongd",
    "check": "bun run check:go && bun run check:js",
    "check:go": "go test ./...",
    "check:js": "bun --filter @sikong/tooling test",
    "dev:cli": "go run ./cmd/sikong",
    "dev:daemon": "go run ./cmd/sikongd",
    "dev:tooling": "bun --filter @sikong/tooling dev"
  }
}
