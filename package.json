{
  "name": "agent-loop",
  "version": "0.0.0",
  "description": "Unified executor over Claude Agent SDK, Codex app-server, Cursor Agent SDK, and Vercel AI SDK. One call = one full agent loop, with skills, MCP, tools, and cross-backend lifecycle hooks + steering.",
  "type": "module",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters/mock": {
      "types": "./src/adapters/mock.ts",
      "default": "./src/adapters/mock.ts"
    },
    "./adapters/claude": {
      "types": "./src/adapters/claude.ts",
      "default": "./src/adapters/claude.ts"
    },
    "./adapters/codex": {
      "types": "./src/adapters/codex.ts",
      "default": "./src/adapters/codex.ts"
    },
    "./adapters/cursor": {
      "types": "./src/adapters/cursor.ts",
      "default": "./src/adapters/cursor.ts"
    },
    "./adapters/ai-sdk": {
      "types": "./src/adapters/ai-sdk.ts",
      "default": "./src/adapters/ai-sdk.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agent",
    "agent-loop",
    "executor",
    "claude",
    "codex",
    "cursor",
    "ai-sdk",
    "llm",
    "mcp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
