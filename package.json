{
  "name": "sikong",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:go",
    "build:go": "go build -o dist/sikong ./cmd/sikong && go build -o dist/sikongd ./cmd/sikongd",
    "check": "bun run check:go && bun run typecheck && bun run lint && bun run fmt:check && bun run check:js",
    "check:go": "go test ./...",
    "check:js": "bun --filter agent-loop test",
    "dev:cli": "go run ./cmd/sikong",
    "dev:daemon": "go run ./cmd/sikongd",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsgo --project tsconfig.json && bun --filter agent-loop typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260613.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  }
}
