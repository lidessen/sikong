{
  "name": "wakespace-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter wakespace build",
    "build:cli": "bun run --filter wakespace build:cli",
    "release:check": "bun run typecheck && bun run test && bun run build && git diff --check && cd packages/wakespace && npm publish --dry-run",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
